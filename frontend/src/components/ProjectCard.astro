---
interface Props {
  title: string;
  description: string;
  imageUrl: string;
  githubUrl?: string;
  liveUrl?: string;
}

const { title, description, imageUrl, githubUrl, liveUrl } = Astro.props;
---

<div class="card group">
  <!-- Image -->
  <div class="aspect-square overflow-hidden bg-surface">
    {imageUrl ? (
      <img
        src={imageUrl}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-muted">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
      </div>
    )}
  </div>

  <!-- Content -->
  <div class="p-4">
    <h3 class="text-lg font-semibold text-text mb-2">{title}</h3>
    <p class="text-muted text-sm mb-4 line-clamp-3">{description}</p>

    <!-- Links -->
    <div class="flex gap-3">
      {githubUrl && (
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-link hover:text-hover"
        >
          GitHub
        </a>
      )}
      {liveUrl && (
        <a
          href={liveUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-link hover:text-hover"
        >
          Live Demo
        </a>
      )}
    </div>
  </div>
</div>